# Production Environment Configuration
# This is an example for production deployments
# Copy to .env and customize with your production values

ENVIRONMENT=production
DEBUG=False
SECRET_KEY=your-very-secure-secret-key-min-50-chars-regenerate-often

# Database Configuration
DB_NAME=tradelink_prod
DB_USER=tradelink_user
DB_PASSWORD=your-secure-db-password
DB_HOST=db
DB_PORT=5432

# Redis Configuration
REDIS_PASSWORD=your-secure-redis-password
REDIS_HOST=redis

# Django Settings
ALLOWED_HOSTS=azizdali.uz,www.azizdali.uz,api.azizdali.uz

# JWT Configuration
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# External Services
FCM_SERVER_KEY=your-production-fcm-key
GOOGLE_MAPS_API_KEY=your-production-google-maps-key
SMS_API_KEY=your-production-sms-key
SMS_PROVIDER=eskiz

# Sentry Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# AWS S3 / Cloudflare R2 (optional)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION_NAME=

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password

# Superuser (will be created on first startup)
SUPERUSER_USERNAME=admin
SUPERUSER_PASSWORD=your-secure-admin-password
SUPERUSER_EMAIL=admin@azizdali.uz

# SSL/TLS Configuration
# Set to True when SSL certificates are properly configured
USE_HTTPS=True
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# CORS Settings (restrict to specific domains)
CORS_ALLOWED_ORIGINS=https://azizdali.uz,https://www.azizdali.uz,https://api.azizdali.uz

# HSTS Settings
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Logging and Monitoring
DJANGO_LOG_LEVEL=INFO
LOG_FILE_PATH=/var/log/tradelink/django.log

# Application Metadata
APP_NAME=TradeLink
APP_VERSION=1.0.0
TIMEZONE=Asia/Tashkent
LANGUAGE_CODE=uz
