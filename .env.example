# Environment Variables Configuration Guide
# Copy this file to .env and fill in your actual values

# ===========================
# ENVIRONMENT SETUP
# ===========================
ENVIRONMENT=development
# Options: development, production
# Use 'development' for local testing (SQLite, debug tools, verbose logs)
# Use 'production' for deployed (PostgreSQL, security hardened, minimal logs)

# ===========================
# DJANGO SECURITY
# ===========================
SECRET_KEY=your-super-secret-key-change-in-production-must-be-50-characters-long
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# CRITICAL: Change before deploying to production
# Minimum 50 characters for security

DEBUG=True
# Should be False in production
# WARNING: Never set to True in production (exposes secret keys in error pages)

ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
# Comma-separated list of allowed domains
# In production, add your actual domain

# ===========================
# DATABASE CONFIGURATION
# ===========================
# For development (SQLite):
DATABASE_URL=sqlite:///db.sqlite3

# For production (PostgreSQL + PostGIS):
# DATABASE_URL=postgresql://username:password@localhost:5432/tradelink_db
# Don't forget: CREATE EXTENSION postgis; in PostgreSQL

DB_ENGINE=django.contrib.gis.db.backends.postgis
# Options:
#   django.db.backends.sqlite3 (development)
#   django.contrib.gis.db.backends.postgis (production with PostGIS)

DB_NAME=tradelink_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432
# PostgreSQL connection details (only used if not using DATABASE_URL)

# ===========================
# REDIS CONFIGURATION
# ===========================
REDIS_URL=redis://localhost:6379/0
# For development: redis://localhost:6379/0
# For production (Docker): redis://redis:6379/0
# Format: redis://host:port/db_number

REDIS_CACHE_DB=1
# Separate database for cache isolation
# Django cache uses this database

CACHES_BACKEND=django.core.cache.backends.redis.RedisCache
# Use 'django.core.cache.backends.locmem.LocMemCache' for development without Redis

# ===========================
# JWT TOKEN CONFIGURATION
# ===========================
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
# Access token expires in 15 minutes
# Used for API requests
# When expired, user must refresh token

JWT_REFRESH_TOKEN_LIFETIME_DAYS=30
# Refresh token expires in 30 days
# Used to get new access tokens
# When expired, user must login again

JWT_ROTATE_REFRESH_TOKENS=True
# If True, new refresh token issued on rotation
# Old refresh tokens blacklisted (previous token becomes invalid)
# Improves security at cost of more database queries

JWT_BLACKLIST_AFTER_ROTATION=True
# If True, old refresh tokens added to blacklist
# Prevents replay attacks with stolen tokens

# ===========================
# CORS CONFIGURATION
# ===========================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourdomain.com
# Comma-separated list of frontend URLs allowed to access API
# In development: http://localhost:3000 (React), http://localhost:8000 (yourself)
# In production: https://yourdomain.com
# CRITICAL: Never use * in production (security risk)

CORS_ALLOW_CREDENTIALS=True
# Allow credentials in cross-origin requests
# Required for cookie-based or token-based authentication

# ===========================
# FIREBASE CLOUD MESSAGING (Push Notifications)
# ===========================
FIREBASE_CREDENTIALS_PATH=/home/deploy/tradelink/firebase-credentials.json
# Path to Firebase Service Account JSON file
# Download from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Keep this file secure and never commit to git
# In production: /home/deploy/tradelink/firebase-credentials.json
# In development: ./config/firebase-credentials.json (for testing)

FIREBASE_PROJECT_ID=your-firebase-project-id
# Get from: Firebase Console > Project Settings > General tab
# Example: my-project-123456
# Used to initialize Firebase Admin SDK

SMS_PROVIDER=twilio
# Options: twilio, kazahstan-provider, etc.
# Used for OTP sending during authentication

TWILIO_ACCOUNT_SID=your-twilio-account-sid
# Get from: Twilio Console > Account > Account SID
# Used for sending SMS over Twilio

TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Get from: Twilio Console > Account > Auth Token
# Secret key for Twilio API

TWILIO_PHONE_NUMBER=+1234567890
# Your Twilio phone number
# Must be verified in Twilio Console

# ===========================
# FILE STORAGE CONFIGURATION
# ===========================
MEDIA_ROOT=/app/media
# Where uploaded files stored
# For development: ./media (local)
# For Docker: /app/media (in container)

MEDIA_URL=/media/
# URL prefix for accessing media files
# Served by Nginx in production

STATIC_ROOT=/app/static
# Where static files collected
# For development: ./static (local)
# For Docker: /app/static (in container)

STATIC_URL=/static/
# URL prefix for accessing static files

DEFAULT_FILE_STORAGE=django.core.files.storage.FileSystemStorage
# Options:
#   django.core.files.storage.FileSystemStorage (local files)
#   storages.backends.s3boto3.S3Boto3Storage (AWS S3)

# ===========================
# LOGGING CONFIGURATION
# ===========================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Development: DEBUG (verbose)
# Production: INFO or WARNING (minimal)

LOG_FILE=/var/log/tradelink/django.log
# Where to write logs
# For development: ./logs/django.log (local)
# For Docker: /var/log/tradelink/django.log

# ===========================
# CELERY CONFIGURATION
# ===========================
CELERY_BROKER_URL=redis://localhost:6379/2
# Message broker for Celery tasks
# Format: redis://host:port/db_number
# Use different db than REDIS_URL (avoid conflicts)

CELERY_RESULT_BACKEND=redis://localhost:6379/2
# Where to store task results
# Same as BROKER_URL for simplicity

CELERY_TASK_SERIALIZER=json
# Data format for task serialization
# json (default, human-readable)

CELERY_ACCEPT_CONTENT=json,yaml,msgpack
# Accepted task serialization formats

# ===========================
# API CONFIGURATION
# ===========================
API_PAGINATION_PAGE_SIZE=20
# Default items per page in list endpoints
# GET /api/v1/products/?page=1 returns 20 products

API_BASE_URL=http://localhost:8000
# Full URL to API (used for links in responses)
# Development: http://localhost:8000
# Production: https://yourdomain.com

# ===========================
# SECURITY HEADERS
# ===========================
SECURE_SSL_REDIRECT=False
# Redirect HTTP to HTTPS
# False for development (no HTTPS)
# True for production (enforce HTTPS)

SESSION_COOKIE_SECURE=False
# Only send cookies over HTTPS
# False for development
# True for production

CSRF_COOKIE_SECURE=False
# Only send CSRF token over HTTPS
# False for development
# True for production

# ===========================
# APPLICATION SETTINGS
# ===========================
OTP_LENGTH=6
# Length of one-time password
# 6 digits is standard

OTP_EXPIRY_MINUTES=10
# OTP valid for 10 minutes
# After this, user must request new OTP

MAX_OTP_ATTEMPTS=5
# User can try wrong OTP 5 times
# After this, request new OTP

PHONE_REGEX=^\+998[0-9]{9}$
# Phone number format validation (Uzbekistan)
# +998 country code, 9 digits

# ===========================
# GEOLOCATION SETTINGS
# ===========================
DEFAULT_SEARCH_RADIUS_KM=10
# Default radius for nearby dealers search
# GET /api/v1/dealers/nearby/?radius=10

LOCATION_PRECISION_DECIMALS=6
# Decimal places for latitude/longitude
# 6 decimals ≈ 0.1 meter precision

# ===========================
# RATE LIMITING
# ===========================
THROTTLE_ANONYMOUS_RATE=100/hour
# Anonymous users (no token): 100 requests per hour

THROTTLE_USER_RATE=1000/hour
# Authenticated users: 1000 requests per hour

# ===========================
# DEVELOPMENT TOOLS (Only in development!)
# ===========================
DJANGO_EXTENSIONS=True
# Install django-extensions for extra commands

# ===========================
# SMS Service Configuration
# ===========================
# Supported: 'eskiz' or 'playmobile'
SMS_PROVIDER=eskiz
SMS_API_KEY=your-sms-service-api-key
SMS_SENDER_NAME=TradeLink

# ===========================
# Email Configuration
# ===========================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For production, change to:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# ===========================
# AWS S3 / Cloudflare R2 Configuration
# ===========================
USE_S3=False
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=tradelink-media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=your-custom-domain.com

# ===========================
# Sentry Error Tracking
# ===========================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ===========================
# CORS Configuration
# ===========================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8080,https://azizdali.uz,https://www.azizdali.uz,https://api.azizdali.uz

# ===========================
# Logging
# ===========================
DJANGO_LOG_LEVEL=INFO

# ===========================
# Celery Configuration
# ===========================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ===========================
# Application Settings
# ===========================
APP_NAME=TradeLink
APP_VERSION=1.0.0

# ===========================
# Timezone
# ===========================
TIME_ZONE=Asia/Tashkent
LANGUAGE_CODE=uz
